PORT=3000
HOST=0.0.0.0

# Supabase (free tier at supabase.com)
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# Whisper model (runs locally, no API key needed)
# Options: Xenova/whisper-tiny | whisper-base | whisper-small | whisper-medium | whisper-large-v3
# whisper-small is a good balance of speed and accuracy
WHISPER_MODEL=Xenova/whisper-small

# Where to cache the downloaded model (downloaded once on first run)
WHISPER_CACHE_DIR=./models
