PORT=3000
HOST=0.0.0.0

# ─── Whisper model (runs locally, no API key needed) ───

# Model size options:
#   Xenova/whisper-tiny     — fastest, less accurate  (~75MB)
#   Xenova/whisper-base     — fast, decent            (~145MB)
#   Xenova/whisper-small    — balanced (default)      (~250MB)
#   Xenova/whisper-medium   — accurate, slow          (~770MB)
#   Xenova/whisper-large-v3 — best, very slow         (~1.5GB)
WHISPER_MODEL=Xenova/whisper-small

# Where to cache the downloaded model (downloaded once on first run)
WHISPER_CACHE_DIR=./models

# Device — CPU vs GPU:
#   auto — CPU (default, works everywhere)
#   cuda — NVIDIA GPU (requires CUDA + onnxruntime-node GPU build)
WHISPER_DEVICE=auto

# Precision:
#   q8   — quantized 8-bit (CPU default, fast + memory efficient)
#   fp16 — half precision  (GPU recommended)
#   fp32 — full precision  (GPU, best quality)
WHISPER_DTYPE=q8
